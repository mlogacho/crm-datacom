# CRM DataCom - Environment variables template
# Use this file as a safe reference and copy it to .env.
# Do not store real credentials in this file.

# PostgreSQL database name.
# If DB_NAME is empty, Django uses local SQLite (db.sqlite3).
DB_NAME=crm_datacom

# PostgreSQL user.
DB_USER=crm_user

# PostgreSQL password.
DB_PASSWORD=change-me

# PostgreSQL host.
DB_HOST=localhost

# PostgreSQL port.
DB_PORT=5432
