# Variables de Entorno — CRM DataCom
# Copiar este archivo como .env y completar con los valores reales
# NUNCA subir el archivo .env al repositorio

# ─── Django ───────────────────────────────────────────────
SECRET_KEY=cambia_esto_por_una_clave_secreta_muy_larga_y_aleatoria
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de Datos (PostgreSQL) ───────────────────────────
# Dejar vacío para usar SQLite (solo desarrollo)
DB_NAME=crm_datacom
DB_USER=crm_user
DB_PASSWORD=password_seguro
DB_HOST=localhost
DB_PORT=5432

# ─── Archivos ─────────────────────────────────────────────
MEDIA_ROOT=/var/www/crm-datacom/media
