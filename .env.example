# ================================================================
# CRM DataCom — Plantilla de Variables de Entorno (.env.example)
# ================================================================
#
# INSTRUCCIONES:
# 1. Copiar este archivo a .env en el directorio raíz
# 2. Reemplazar valores de ejemplo con valores reales
# 3. NUNCA commitear .env a Git (ver .gitignore)
# 4. Mantener .env.example sin credenciales sensibles (para referencia)
#
# SEGURIDAD:
# - Cambiar SECRET_KEY antes de producción
# - Usar DEBUG=False en producción
# - Cambiar contraseñas de BD, email, etc.
# - Restringir ALLOWED_HOSTS a dominios reales
#
# ================================================================

# ================================================================
# DJANGO - CONFIGURACIÓN CORE
# ================================================================

# Clave secreta para sesiones y tokens (CAMBIAR en producción)
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-6gj^lsmcled&ycs_29+t1dk#1)7j3*t_2*v(6of2f6%%qj8ik9

# Modo debug - SIEMPRE False en producción
# DEBUG=True activa traceback de errores (seguridad comprometida)
DEBUG=True

# Hosts permitidos (separados por coma)
# En desarrollo: localhost,127.0.0.1
# En producción: yourdomain.com,www.yourdomain.com,api.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ================================================================
# BASE DE DATOS
# ================================================================

# DESARROLLO: SQLite (por defecto)
# No requiere variables de entorno de BD, se usa db.sqlite3 automáticamente

# PRODUCCION: PostgreSQL
# Cuando se define DB_NAME, Django automáticamente usa PostgreSQL
# Comentar estas líneas (o dejarlas en blanco) para usar SQLite

# Nombre de la base de datos
# DB_NAME=crm_datacom

# Usuario de acceso a la BD
# DB_USER=crm_user

# Contraseña del usuario PostgreSQL (CAMBIAR)
# DB_PASSWORD=your-secure-password-here

# Host del servidor PostgreSQL
# DB_HOST=localhost
# Para producción remota: db.company.com o IP

# Puerto de PostgreSQL (5432 es defecto)
# DB_PORT=5432

# ================================================================
# CORREO ELECTRÓNICO (Email)
# ================================================================
# Usado para notificaciones, recordatorios, cambios de contraseña

# Servidor SMTP
# EMAIL_HOST=smtp.gmail.com

# Puerto SMTP
# EMAIL_PORT=587

# Usuario de correo (desde)
# EMAIL_HOST_USER=crm@datacom.com.ec

# Contraseña de correo (con Gmail: usar contraseña de aplicación)
# EMAIL_HOST_PASSWORD=your-app-password

# Para desarrollo local (console backend):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Para producción (SMTP):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# ================================================================
# CORS (Cross-Origin Resource Sharing)
# ================================================================
# Controla acceso desde dominios externos (frontend)

# En desarrollo:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# En producción:
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ================================================================
# CELERY (Futuro - Tareas Asincrónicas)
# ================================================================
# Para procesamiento en background (correos, reportes, etc)

# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ================================================================
# REDIS (Futuro - Cache)
# ================================================================

# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# ================================================================
# AUTENTICACIÓN Y SEGURIDAD (Futuro)
# ================================================================

# Para TOTP 2FA (Two-Factor Authentication)
# TOTP_ENABLED=True

# Tiempo de vida de token (segundos)
# TOKEN_EXPIRY_SECONDS=86400

# ================================================================
# LOGGING (Futuro)
# ================================================================

# LOG_LEVEL=INFO
# LOG_FILE_PATH=logs/crm.log

# ================================================================
# PARÁMETROS DE APLICACIÓN ESPECÍFICOS
# ================================================================

# Zona horaria (UTC recomendado)
# TIME_ZONE=UTC

# Idioma
# LANGUAGE_CODE=es-es

# IVA por defecto para Ecuador (15%)
# DEFAULT_TAX_RATE=0.15

# ================================================================
# VARIABLES DE DESARROLLO SOLAMENTE
# ================================================================

# Para ejecutar tests:
# TESTING=True

# Para debugger:
# DEBUGGER_ENABLED=True

# ================================================================
# NOTAS IMPORTANTES
# ================================================================

# 1. Este archivo es una PLANTILLA. Nunca commitear .env a Git.
#
# 2. Para cada entorno, copiar .env.example a:
#    - Desarrollo: .env (incluida en .gitignore)
#    - CI/Testing: .env.test
#    - Staging: .env.staging
#    - Producción: .env (en servidor, configurado via SSH)
#
# 3. Nombres de variables deben coincidir exactamente en settings.py
#    Utilizar: os.environ.get("VARIABLE_NAME", default_value)
#
# 4. En producción, usar gestor de secretos:
#    - AWS Secrets Manager
#    - HashiCorp Vault
#    - Azure Key Vault
#    - Kubernetes Secrets
#
# 5. Generar SECRET_KEY seguro:
#    python manage.py shell -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# 6. Cambiar contraseña de súper usuario después de instalación:
#    python manage.py changepassword admin
#
# ================================================================
